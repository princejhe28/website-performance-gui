# ── PageSpeed Insights ────────────────────────────────────────────────────────
# Google API key with "PageSpeed Insights API" enabled
PSI_API_KEY=

# ── Vercel Cron Auth ──────────────────────────────────────────────────────────
# A secret string; Vercel automatically sends this as a Bearer token on cron requests.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-populated by the Vercel Blob integration; set manually for local dev.
BLOB_READ_WRITE_TOKEN=

# ── Asana (optional) ─────────────────────────────────────────────────────────
# Personal access token from https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=
# GID of the Asana project where tasks should be created
ASANA_PROJECT_GID=

# ── Grafana Cloud ─────────────────────────────────────────────────────────────
# Base URL of your Grafana Cloud stack, e.g. https://myorg.grafana.net
GRAFANA_CLOUD_URL=
# Numeric Metrics user ID: Grafana Cloud → Stack → Grafana Metrics (Prometheus) → Details
GRAFANA_CLOUD_USER=
# API key with the "MetricsPublisher" role
GRAFANA_CLOUD_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Website Performance Dashboard"
